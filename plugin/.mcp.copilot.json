{
  "mcpServers": {
    "agentmemory": {
      "type": "local",
      "command": "python",
      "args": ["${COPILOT_PLUGIN_ROOT}/scripts/mcp_stdio.py"],
      "env": {
        "AGENTMEMORY_URL": "${AGENTMEMORY_URL:-http://localhost:3111}",
        "AGENTMEMORY_SECRET": "${AGENTMEMORY_SECRET:-}",
        "AGENTMEMORY_TOOLS": "${AGENTMEMORY_TOOLS:-all}"
      },
      "tools": ["*"]
    }
  }
}
